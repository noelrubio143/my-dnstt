#!/bin/bash

rm -f ./install || true

GITHUB_TOKEN="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"

menu="https://raw.githubusercontent.com/hahacrunchyrollls/amber-installer/refs/heads/main/menu"
websocket="https://raw.githubusercontent.com/hahacrunchyrollls/amber-installer/refs/heads/main/websocket"

#BASHRC="/root/.bashrc"

apt -y update && apt install cron -y

apt -y install iptables-persistent wget screen lsof vnstat bmon

apt -y install at
systemctl enable --now atd

clear
echo -e "$GREEN"
echo -e "╔═════════════════════════════════╗"
echo -e "  INSTALLING WEBSOCKET"
echo -e "╚═════════════════════════════════╝"
echo -e "$NC"
curl -skLO -H "Authorization: token $GITHUB_TOKEN" -H "Accept: application/vnd.github.v3.raw" "$websocket"
chmod +x websocket || true
./websocket || true

clear
echo -e "$GREEN"
echo -e "╔═════════════════════════════════╗"
echo -e "       DOWNLOADING MENU"
echo -e "╚═════════════════════════════════╝"
echo -e "$NC"
curl -skLO -H "Authorization: token $GITHUB_TOKEN" -H "Accept: application/vnd.github.v3.raw" "$menu"
chmod +x menu || true
mv menu /usr/bin/menu || true

clear
echo -e "$GREEN"
echo -e "╔═════════════════════════════════╗"
echo -e "   DNSTT installation completed"
echo -e "╚═════════════════════════════════╝"
echo -e "$NC"

create_profile() {
    cat > /etc/profile.d/amber.sh <<'EOF'
#!/bin/bash
clear

NC='\033[0m'

history -c 2>/dev/null || true
history -w 2>/dev/null || true
rm -rf /var/log/journal/* /run/log/journal/* /var/log/lastlog 2>/dev/null || true
rm -f ~/.bash_history 2>/dev/null || true

echo -e "$NC"
echo -e "------------------------------"
echo -e "   Main Command: menu"
echo -e "------------------------------"
echo -e "$NC"

service_status() {
    systemctl is-active --quiet "$1" && echo -e "\033[32m●\033[0m" || echo -e "\033[31m●\033[0m"
}

echo -e "\033[1mSERVICE STATUS:\033[0m "
echo -n "WEBSOCKET  - "; service_status websocket
echo -e "------------------------------"
echo -e "IP : $(curl -s https://api.ipify.org)"
echo -e "A  : $(cat /etc/domain 2>/dev/null)"
echo -e "------------------------------"
EOF

    chmod +x /etc/profile.d/amber.sh || true
}

trap create_profile EXIT

create_profile || true

echo -e "${GREEN}Installation finished. Rebooting system in 3 seconds to complete setup...${NC}"
sleep 3

if command -v systemctl >/dev/null 2>&1; then
    systemctl reboot --force || shutdown -r now || reboot -f
else
    shutdown -r now || reboot -f
fi

# If reboot commands return, exit
exit 0
